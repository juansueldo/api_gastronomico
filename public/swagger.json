    "/clientes": {
      "post": {
        "summary": "Crear un nuevo cliente",
        "tags": [
          "Clientes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "telefono": {
                    "type": "string"
                  },
                  "direccion": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cliente creado"
          },
          "400": {
            "description": "Error de validación"
          }
        }
      },
      "get": {
        "summary": "Listar todos los clientes",
        "tags": [
          "Clientes"
        ],
        "responses": {
          "200": {
            "description": "Lista de clientes"
          }
        }
      }
    },
